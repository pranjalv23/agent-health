# LLM providers (at least one required)
GROQ_API_KEY=
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agent_health

# Mem0 — long-term user memory (fitness progress, preferences)
MEM0_API_KEY=

# MCP tool server (Tavily search, Firecrawl scraping)
MCP_SERVER_URL=http://mcp-tool-servers:8010/mcp

# Service URLs
BACKEND_URL=http://localhost:9005
AGENT_PUBLIC_URL=http://localhost:9005

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional SSL
SSL_CERTFILE=
SSL_KEYFILE=

# Optional: increase GitHub rate limit for MCP tool server (not used here directly)
# GITHUB_TOKEN=

# Logging
LOG_LEVEL=INFO
